# Streamlit secrets — 部署時複製此檔為 `.streamlit/secrets.toml`
# 並填入真實值。`secrets.toml` 已被 .gitignore 排除，不會被 commit。
#
# Streamlit Cloud 部署時，請改在 dashboard 的「Settings → Secrets」貼上下列內容
# （不需要實體 secrets.toml 檔）：
#   https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management

# ============================================================
# OpenAI API Key — 供 Ch.9 學長 AI 實戰顧問使用
# ============================================================
# 取得：https://platform.openai.com/api-keys
# 建議：使用 project-scoped key 並設定每月支出上限，避免外洩時帳單爆炸
OPENAI_API_KEY = "sk-proj-REPLACE_ME_WITH_REAL_KEY"
